DOMAIN=foreverteck.com
ACME_EMAIL=you@example.com

# Cloudflare DNS challenge (required for TLS)
CLOUDFLARE_EMAIL=you@example.com
CLOUDFLARE_DNS_API_TOKEN=__REPLACE_ME__

# Traefik dashboard basic auth (htpasswd format, required if dashboard exposed)
# Example: admin:$apr1$H6uskkkW$IgXLP6ewTrSuBkTrqE8wj/
DASHBOARD_AUTH=__REPLACE_ME__

# Host port for the Next.js app
CATALOG_HOST_PORT=3001

# Optional: cross-agent prompt optimizer (OpenAI compatible)
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=
CROSS_AGENT_MODELS=gpt-4o-mini

# Optional: OpenClaw OpenResponses critic
OPENCLAW_OPENRESPONSES_URL=http://host.docker.internal:18789/v1/responses
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=main

# Optional: IPFS HTTP API upload (Kubo-compatible)
IPFS_API_URL=
IPFS_API_AUTH=
IPFS_GATEWAY_BASE=https://ipfs.io/ipfs

# Optional: maintenance mode (returns 503 for pages + APIs)
MAINTENANCE_MODE=0

# Optional: Wolfram Alpha (used by fusion-service/quantum-image-gen features)
WOLFRAM_ALPHA_APPID=

# Optional: Cloudflare integration tokens for web-app
CF_API_TOKEN=
CF_CLIENT_ID=
CF_VERSION_ID=
CF_EMAIL_ROUTING_TOKEN=

