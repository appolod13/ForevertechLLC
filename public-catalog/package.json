{
  "name": "public-catalog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "dev:https": "next dev -p 3002 --experimental-https",
    "dev:https:cert": "next dev -p 3002 --experimental-https --experimental-https-key ./certificates/localhost-key.pem --experimental-https-cert ./certificates/localhost.pem",
    "build": "next build",
